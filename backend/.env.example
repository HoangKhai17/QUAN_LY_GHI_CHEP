# ─── Server ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── Database ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5433
DB_NAME=quan_ly_ghi_chep
DB_USER=admin
DB_PASSWORD=secret

# ─── JWT (Access Token 15 phút + Refresh Token 7 ngày) ──────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_REFRESH_EXPIRES=7d

# ─── Zalo OA ─────────────────────────────────────────────────────
ZALO_OA_TOKEN=
ZALO_WEBHOOK_SECRET=

# ─── File Storage (chọn Cloudinary hoặc AWS S3) ─────────────────
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
SIGNED_URL_EXPIRES=3600

# ─── OCR ─────────────────────────────────────────────────────────
GOOGLE_VISION_KEY_FILE=./credentials/google-vision.json

# ─── Monitoring ──────────────────────────────────────────────────
SENTRY_DSN=

# ─── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
