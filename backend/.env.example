# ─── Server ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── Database ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5433
DB_NAME=quan_ly_ghi_chep
DB_USER=admin
DB_PASSWORD=secret

# ─── JWT (Access Token 15 phút + Refresh Token 7 ngày) ──────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_REFRESH_EXPIRES=7d

# ─── Webhook Base URL (ngrok khi dev, domain thật khi production) ────
# Không có trailing slash. Để trống nếu chưa có ngrok.
WEBHOOK_BASE_URL=

# ─── Zalo OA ─────────────────────────────────────────────────────
ZALO_OA_TOKEN=
ZALO_WEBHOOK_SECRET=

# ─── Telegram Bot ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# ─── File Storage ────────────────────────────────────────────────
# Provider hiện tại: cloudinary | Tương lai: s3, r2, local
STORAGE_PROVIDER=cloudinary
# Cloudinary: lấy từ dashboard.cloudinary.com → Settings → API Keys
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
# Thời hạn URL ảnh (giây) — dùng cho S3/R2, Cloudinary free bỏ qua
SIGNED_URL_EXPIRES=3600

# ─── AI / OCR ────────────────────────────────────────────────────
# Provider: gemini (mặc định) | vision | tesseract
AI_PROVIDER=gemini
# Google Gemini — lấy API key từ aistudio.google.com
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── Monitoring ──────────────────────────────────────────────────
SENTRY_DSN=

# ─── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
